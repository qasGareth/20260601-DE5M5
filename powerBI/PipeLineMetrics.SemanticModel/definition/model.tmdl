model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-GB
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Customers","Error_Summary","Error_Customers","Error_Transactions","Transactions","Metrics"]

annotation PBI_ProTooling = ["DevMode"]

ref table Customers
ref table Error_Summary
ref table Error_Customers
ref table Error_Transactions
ref table Transactions
ref table Metrics

ref cultureInfo en-US

